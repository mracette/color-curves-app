{
  "name": "color-curves",
  "version": "1.0.0-beta.0",
  "description": "Design color palettes by drawing curves through color space.",
  "author": "Mark Racette",
  "repository": {
    "type": "git",
    "url": "https://github.com/mracette/color-curves-app.git",
    "directory": "packages/color-curves"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "generate:presets": "tsx scripts/generate-presets.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
